{
// HYPRLAND 
"hyprland/workspaces#icons": {
    "format": " {name} {icon} ",
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "sort-by-number": true,
    "format-icons": {
      "1": "ΎΕι ",
      "2": "≤░Ι╣ ",
      "3": "≤░ιχ ",
      "4": "≤░βψ ",
      "5": "≤░ΟΕ ",
      "6": "≤░ΥΥ ",
      "default": "ΎΗΤ ",
    },
    "persistent-workspaces": {
      "*": [ 1, 2, 3, 4, 5 ],
    },
    "ignore-workspaces": [
      "*scratch*",
    ],
},

"hyprland/workspaces#numbers": {
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "sort-by-number": true,
    "persistent-workspaces": {
      "*": [ 1, 2, 3, 4, 5 ],
    },
    "ignore-workspaces": [
      "*scratch*",
    ],
},

"hyprland/window": {
    "format": "{class} - {title}",
    "max-length": 40,
    "separate-outputs": false,  //Seperate window for each workspace
    "offscreen-css" : true,
    "offscreen-css-text": "(inactive)",
    "rewrite": {
      "firefox - (.*)": "≤░Ι╣ Firefox",
      "kitty - (.*)": "> Kitty",
      "vivaldi(.*)": "ΌυΒ Vivaldi",
    },
},

"hyprland/language": {
  "format": "ΎΕε  {}",
  "format-en": "en",
  "format-de": "de",
},

// DISTRO ICON 
"custom/icon": {
  "format": "ΎΝΥ ",
  "on-click": "pkill rofi || rofi -show drun"
},

// SEPARATOR
"custom/separator_pipe": {
  "format": "|",
},

// RADIO
"custom/fine_radio": {
  format: "fine-radio-status",
  "interval": 2,
},

// POWER MENU 
"custom/power": {
    "format": "έΠ╗ ",
    "exec": "echo ; echo ≤░θκ power // blur",
    "on-click": "wlogout",
    "interval" : 86400, // once every day
    "tooltip": false,
},
 
// GROUP

"group/laptop": {
    "orientation": "horizontal",
    "modules": [
      "backlight",
      "battery",
      ]	
},

// MEDIA PLAYER
"mpris": {
	"interval": 1,
	"format": "{player_icon}  {title} - {artist}",
	"format-paused": "{status_icon}  {title} - {artist}",
	"on-click-middle": "playerctl play-pause",
	"on-click": "playerctl previous",
	"on-click-right": "playerctl next",
	"scroll-step": 5.0,
	"smooth-scrolling-threshold": 1,
	"player-icons": {
		"chromium": "ΎΚρ ",
		"default": "ΎΑζ ",
		"firefox": "≤░Ι╣ ",
		"mopidy": "ΎΑΒ",
		"mpv": "≤░Ρ╣",
		"spotify": "ΎΗ╝",
		"vlc": "≤░Χ╝",
		"Feishin": "ΎΑΒ",
	},
	"status-icons": {
		"paused": "≤░ΡΟ",
		"playing": "ΎΒΜ",
		"stopped": "ΎΒΞ",
	},
	"ignored-players": ["firefox"],
	"max-length": 50,
},
  
"backlight": {
    "interval": 2,
    "align": 0,
    "rotate": 0,
    "format": "{icon} {percent}%",
    "format-icons": ["≤░Δη ", "≤░Δθ ", "≤░Δι "],
    //"format-icons": ["ΌΠΧ ", "ΌΠΩ ", "ΌΠγ ", "≤░Δζ ", "≤░Δη ", "≤░Δθ ", "≤░Δι "],
    //"format": "{icon}",
    //"format-icons": ["ΌΠΧ","ΌΠΨ","ΌΠΩ","ΌΠα","ΌΠβ","ΌΠγ","ΌΠδ","ΌΠε","ΌΠζ","ΌΠη","ΌΠθ","ΌΠι","ΌΠκ","ΌΠλ","ΌΠμ"],
    "tooltip-format": "backlight {percent}%",
    "icon-size": 10,
    "on-click": "",
    "on-click-middle": "",
    "on-click-right": "",
    "on-update": "",
    "on-scroll-up": "",
    "on-scroll-down": "",
    "smooth-scrolling-threshold": 1,
},

"battery": {
    //"interval": 5,
    "align": 0,
    "rotate": 0,
    //"bat": "BAT1",
    //"adapter": "ACAD",
    "full-at": 80,
    "design-capacity": false,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
             },
    "format": "{icon} {capacity}%",
    "format-charging": "ΎΔπ {capacity}%",
    "format-plugged": "≤▒αΨ {capacity}%",
	"format-alt-click": "click",
    "format-full": "{icon} Full",
    "format-alt": "{icon} {time}",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "format-time": "{H}h {M}min",
    "tooltip": false,
    "tooltip-format": "{timeTo} {power}w",
},
"group/system": {
  "orientation": "inherit",
  "drawer": {
    "transition-duration": 256,
    "transition-left-to-right": false,
  },
  "modules": [
    "temperature",
    "network#speed",
    "disk",
    "memory",
    "cpu",
  ],
},
  
"group/audio": {
    "orientation": "horizontal",
    "modules": [
      "pulseaudio",
      "pulseaudio#microphone",
      ]	
},
      
      
"bluetooth": {
    "format": "ΎΛΥ",
    "format-disabled": "≤░Γ│",
    "format-connected": "≤░Γ▒ {num_connections}",
    "tooltip-format": "ΎΛΥ {device_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "ΎΛΥ {device_alias} ≤░ΓΕ{device_battery_percentage}%",
    "tooltip": true,
    "on-click": "blueman-manager",
},
     
"clock": {
    "interval": 1,
    "format": "ΎΑΩ  {:%H:%M %a %d.%m.%y }",
    "on-click": "gnome-calendar",
},
   
"cpu": {
    "format": "{usage}% ≤░Ξδ",  
    "interval": 1,
    "format-alt-click": "click",
    "format-alt": "{icon0}{icon1}{icon2}{icon3} {usage:>2}% ≤░Ξδ",
    "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"],
    "on-click-right": "gnome-system-monitor",
    "justify": "right",
},
    
"disk": {
    "interval": 30,
    //"format": "≤░ΜΛ",
    "path": "/",
    //"format-alt-click": "click",
    "format": "{percentage_used}% ≤░ΜΛ",
    //"tooltip": true,
    "tooltip-format": "{used} used out of {total} on {path} ({percentage_used}%)",
},
    
  
"idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "ΎΙΖ ",
      "deactivated": "ΎΙΕ ",
    },
    "tooltip-format-activated": "Idle-inhibitor: activated",
    "tooltip-format-deactivated": "Idle-inhibitor: deactivated",
    "start-activated": false,
},
    
"memory": {
    "interval": 10,
    "format": "{used:0.1f}G ≤░╛Η",
    "format-alt": "{percentage}% ≤░╛Η",
    "format-alt-click": "click",
    "tooltip": true,
    "tooltip-format": "{used:0.1f}GB/{total:0.1f}G",
    "on-click-right": "kitty --title btop sh -c 'btop'"
},
      
"network": {
    "format": "{ifname}",
    "format-wifi": "{icon}",
    "format-ethernet": "≤░Να",
    "format-disconnected": "≤░Νβ", 
    "tooltip-format": "{ipaddr} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 50,
    "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"],
},

"group/hiddennetwork": {
    "orientation": "inherit",
    "drawer": {
	"transition-duration": 200,
	"transition-left-to-right": false,
    },
    "modules": [ 
	"custom/groupindicator",
	"network#speed",
    ],
},
  
"network#speed": {
    "interval": 1,
    "format": "{ifname}",
    "format-wifi": "{icon} ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
    "format-ethernet": "≤░Να  ΎΕ╣ {bandwidthUpBytes} ΎΕ║ {bandwidthDownBytes}",
    "format-disconnected": "≤░Νβ", 
    "tooltip-format": "{ipaddr}",
    "format-linked": "≤░ΙΒ {ifname} (No IP)",
    "tooltip-format-wifi": "{essid} {icon} {signalStrength}%",
    "tooltip-format-ethernet": "{ifname} ≤░Να",
    "tooltip-format-disconnected": "≤░Νβ Disconnected",
    "max-length": 50,
    "format-icons": ["≤░νψ","≤░νθ","≤░νλ","≤░νξ","≤░νρ"]
},
      
"pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon} ≤░Γ░ {volume}%",
    "format-muted": "≤░ΨΒ",
    "format-icons": {
        "headphone": "ΎΑξ",
        "hands-free": "ΎΑξ",
        "headset": "ΎΑξ",
        "phone": "ΎΓΧ",
        "portable": "ΎΓΧ",
        "car": "ΎΗ╣",
    "default": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "ΎΑρ"], 
    "ignored-sinks": ["Easy Effects Sink"],
    },
    "scroll-step": 5.0,
    "on-click": "pypr toggle audio",
    "tooltip-format": "{icon} {desc} | {volume}%",
    "smooth-scrolling-threshold": 1,
},
      
"pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ΎΕ░ {volume}%",
    "format-source-muted": "ΎΕ▒",
    "on-click": "~/.config/hypr/scripts/Volume.sh --toggle-mic",
    "on-click-right": "pavucontrol -t 4",
    "on-scroll-up": "~/.config/hypr/scripts/Volume.sh --mic-inc",
    "on-scroll-down": "~/.config/hypr/scripts/Volume.sh --mic-dec",
	"tooltip-format": "{source_desc} | {source_volume}%",
    "scroll-step": 5,
},
    
"temperature": {
    "interval": 10,
    "tooltip": true,
    "hwmon-path": ["/sys/class/hwmon/hwmon1/temp1_input", "/sys/class/thermal/thermal_zone0/temp"],
    //"thermal-zone": 0,
    "critical-threshold": 82,
    "format-critical": "{temperatureC}┬░C {icon}",
    "format": "{temperatureC}┬░C {icon}",
    "format-icons": ["≤░Ι╕"],
    "on-click-right": "kitty --title nvtop sh -c 'nvtop'"
},
      
"tray": {
    "icon-size": 18,
    "spacing": 8,
    "show-passive-items": true,
},

"group/hiddentray": {
    "orientation": "inherit",
    "drawer": {
	"transition-duration": 200,
	"transition-left-to-right": false,
    },
    "modules": [ 
	"custom/groupindicator",
	"tray",
    ],
},

"custom/groupindicator": {
    "format": "ΎΕΕ",
    "tooltip": false,
},
      
"wireplumber": {
    "format": "{icon} {volume} %",
    "format-muted": "ΎΣο Mute",
    "on-click": "~/.config/hypr/scripts/Volume.sh --toggle",
    "on-click-right": "pavucontrol -t 3",
    "on-scroll-up": "~/.config/hypr/scripts/Volume.sh --inc",
    "on-scroll-down": "~/.config/hypr/scripts/Volume.sh --dec",
    "format-icons": ["ΎΑο", "ΎΑπ", "≤░Χ╛", "ΎΑρ"], 
},
      
"wlr/taskbar": {
    "format": "{icon} {name} ",
    "icon-size": 15,
    "all-outputs": false,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
          "wofi",
          "rofi",  
                   ]
},
      
"custom/keybinds": {
    "format":"≤░║Β HINT!",
    "exec": "echo ; echo ΎΡΑ Key Hints SUPER H",
    "on-click": "~/.config/hypr/scripts/KeyHints.sh",
    "interval" : 86400, // once every day
    "tooltip": true,
},
      
"custom/lock": {
    "format": "≤░Ν╛{}",
    "exec": "echo ; echo ≤░╖δ  screen lock",
    "interval" : 86400, // once every day
    "tooltip": true,
    "on-click": "~/.config/hypr/scripts/LockScreen.sh",
},
    
"custom/menu": {
    "format": "ΎΖ╝{}",
    "exec": "echo ; echo ≤▒Υθ app launcher",
    "interval" : 86400, // once every day
    "tooltip": true,
    "on-click": "pkill rofi || rofi -show drun -modi run,drun,filebrowser,window",
    "on-click-middle": "~/.config/hypr/scripts/WallpaperSelect.sh",
    "on-click-right": "~/.config/hypr/scripts/WaybarLayout.sh",
},


"custom/power": {
    "format": "έΠ╗ ",
    "exec": "echo ; echo ≤░θκ power // blur",
	"on-click": "~/.config/hypr/scripts/Wlogout.sh",
    "on-click-right": "~/.config/hypr/scripts/ChangeBlur.sh",
    "interval" : 86400, // once every day
    "tooltip": true,
},

"custom/swaync": {
    "tooltip":true,     
    "format": "{icon} {}",
    "format-icons": {
      "notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "none": "ΎΓλ",
      "dnd-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-none": "ΎΘ╖",
      "inhibited-notification": "ΎΓλ<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "inhibited-none": "ΎΓλ",
      "dnd-inhibited-notification": "ΎΘ╖<span foreground='red'><sup>ΎΣΕ</sup></span>",
      "dnd-inhibited-none": "ΎΘ╖"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "sleep 0.1 && swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
},

"custom/weather": {
    "format": "{}",
    "format-alt": "{alt}: {}",
    "format-alt-click": "click",
    "interval": 3600,
    "return-type": "json",
    "exec": "~/.config/hypr/UserScripts/Weather.sh",
    //"exec": "~/.config/hypr/UserScripts/Weather.py",
    "exec-if": "ping wttr.in -c1",
    "tooltip" : true,
},
  
}
  
  
